@page
@model WebApp.Pages.AddressCheckerModel
@{
    ViewData["Title"] = "NZ Address Checker";
}

<h2>NZ Address Checker</h2>
<p class="text-muted">Start typing a New Zealand address for near real-time validation.</p>

<div class="mb-3">
    <label for="addressInput" class="form-label">Address</label>
    <input id="addressInput" class="form-control" placeholder="e.g. 15 Willis St, Wellington" />
</div>

<div id="statusMessage" class="alert d-none" role="alert"></div>
<ul id="suggestions" class="list-group"></ul>

<style>
    #suggestions .list-group-item {
        cursor: pointer;
    }
    #suggestions .list-group-item:hover {
        background-color: #e9ecef;
    }
    #suggestions .list-group-item.active {
        background-color: #0d6efd;
        border-color: #0d6efd;
        color: #fff;
    }
</style>

@section Scripts {
    <script>
        const input = document.getElementById("addressInput");
        const statusMessage = document.getElementById("statusMessage");
        const suggestions = document.getElementById("suggestions");
        let timerId;

        function setMessage(message, type) {
            statusMessage.className = `alert alert-${type}`;
            statusMessage.textContent = message;
        }

        async function validateAddress(query) {
            try {
                const response = await fetch(`/api/address/validate?query=${encodeURIComponent(query)}`);
                if (response.status === 503) {
                    setMessage("Address service is unavailable. Try again shortly.", "danger");
                    renderSuggestions([]);
                    return;
                }

                if (response.status === 504) {
                    setMessage("Address service timed out. Please retry.", "danger");
                    renderSuggestions([]);
                    return;
                }

                const result = await response.json();
                setMessage(result.message, result.isValid ? "success" : "warning");
                renderSuggestions(result.isValid ? [] : (result.suggestions || []));
            } catch {
                setMessage("Unable to validate address right now.", "danger");
                renderSuggestions([]);
            }
        }

        function renderSuggestions(items) {
            suggestions.innerHTML = "";
            items.forEach(item => {
                const li = document.createElement("li");
                li.className = "list-group-item list-group-item-action";
                li.textContent = item;
                li.setAttribute("role", "button");
                li.addEventListener("click", () => selectSuggestion(item));
                suggestions.appendChild(li);
            });
        }

        function selectSuggestion(address) {
            input.value = address;
            clearTimeout(timerId);
            validateAddress(address);
        }

        input.addEventListener("input", () => {
            clearTimeout(timerId);
            const query = input.value.trim();
            if (!query) {
                statusMessage.className = "alert alert-warning";
                statusMessage.textContent = "Please enter an address.";
                suggestions.innerHTML = "";
                return;
            }

            timerId = setTimeout(() => validateAddress(query), 350);
        });
    </script>
}
